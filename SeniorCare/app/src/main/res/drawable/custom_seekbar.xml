<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background: Phần thanh chưa được kéo -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#D3D3D3" />
            <stroke android:width="1dp" android:color="#B0B0B0" />
        </shape>
    </item>

    <!-- Secondary Progress (nếu có) -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="10dp" />
                <solid android:color="#888888" /> <!-- Màu xám cho secondary progress -->
            </shape>
        </clip>
    </item>

    <!-- Primary Progress: Phần thanh đã được kéo -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="10dp" />
                <solid android:color="@color/material_dynamic_primary40" /> <!-- Màu chính cho phần đã kéo -->
            </shape>
        </clip>
    </item>

</layer-list>