<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp"
    tools:context=".SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cài đặt Launcher"
            android:textSize="28sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <!-- Cài đặt kích thước Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kích thước biểu tượng ứng dụng"
            android:textColor="@android:color/black"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <SeekBar
                android:id="@+id/icon_size_seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:min="50"
                android:max="150"
                android:progress="100" />

            <TextView
                android:id="@+id/icon_size_value_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="100%"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
        </LinearLayout>


        <!-- Cài đặt kích thước Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kích thước chữ"
            android:textColor="@android:color/black"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <SeekBar
                android:id="@+id/text_size_seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:min="50"
                android:max="150"
                android:progress="100" />

            <TextView
                android:id="@+id/text_size_value_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="100%"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Cài đặt số cột -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số cột ứng dụng"
            android:textColor="@android:color/black"
            android:textSize="18sp" />

        <RadioGroup
            android:id="@+id/num_columns_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radio_2_columns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 Cột"
                android:layout_marginEnd="16dp"
                android:textColor="@android:color/black"/>

            <RadioButton
                android:id="@+id/radio_3_columns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 Cột"
                android:layout_marginEnd="16dp"
                android:textColor="@android:color/black"/>

            <RadioButton
                android:id="@+id/radio_4_columns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 Cột"
                android:textColor="@android:color/black"/>
        </RadioGroup>

        <!-- Nút Quản lý ứng dụng -->
        <Button
            android:id="@+id/manage_apps_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý ứng dụng trên Launcher"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:backgroundTint="?attr/colorPrimaryVariant"
            android:paddingVertical="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Danh sách ứng dụng đã chọn -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ứng dụng đã chọn"
            android:textColor="@android:color/black"
            android:textSize="18sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/selected_apps_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="77dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false" />

        <!-- Các nút bổ sung (ImageButton) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageButton
                    android:id="@+id/contacts_button"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_contacts"
                    android:background="@drawable/rounded_button_background"
                    android:scaleType="fitCenter"
                    android:contentDescription="Mở Danh bạ" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Danh bạ"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageButton
                    android:id="@+id/font_settings_button"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_font_settings"
                    android:background="@drawable/rounded_button_background"
                    android:scaleType="fitCenter"
                    android:contentDescription="Cài đặt Font chữ" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cỡ chữ"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageButton
                    android:id="@+id/set_default_launcher_button"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_home_settings"
                    android:background="@drawable/rounded_button_background"
                    android:scaleType="fitCenter"
                    android:contentDescription="Đặt làm Launcher mặc định" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đặt mặc định"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>